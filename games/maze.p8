pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
-- tama-gatcha! add-on
-- minigame: maze
#include ../includes/IS_HTML.p8.lua
root = "../"
#include ../includes/helper_functions.p8.lua
#include ../includes/asset_loader.p8.lua
#include ../includes/byte_streamer.p8.lua
#include ../includes/class__pet.p8.lua
#include ../includes/data.p8.lua

-- wrapper for playing music with respect to mute
function play_music(key, force)
 if not settings.mute or not key then
  asset_loader.play_music(key, force)
 end
end

for x = 0, 7 do
 for y = 0, 3 do
  asset_loader.spr_allocation[y * 16 + x] = true
 end
end
for x = 0, 40 do
 for y = 0, 22 do
  asset_loader.map_allocation[y * 128 + x] = true
 end
end

asset_loader.sfx_allocation[0] = true
asset_loader.sfx_allocation[31] = true
-->8

function get_tile(x, y)
 local overlay_tile = mget(x \ 8, y \ 8)
 if overlay_tile ~= 0 then
  return overlay_tile
 end
 return mget(x \ 8 + map_x, y \ 8 + map_y)
end

-->8

function _init()
 load_data()
 --max is 12,10
 map_x = flr(rnd(6)) * 2 + 15
 map_y = flr(rnd(5)) * 2 - 2
 char_x = 16
 char_y = 8
 tick⧗ = time()
 start_time = time()
 temp_visuals = nil
 asset_loader.play_music("fiction")
end

function _update()
 if results then
  if time() - start_time > 2 then
   _end()
  end
  return
 end
 local change_x = char_x
 local change_y = char_y
 --moving
 if tick⧗ + 0.15 < time() then
  if not (btnp_axis(⬅️, ➡️) == 0 and btnp_axis(⬆️, ⬇️) == 0) then
   tick⧗ = time()
  end
  change_x = btnp_axis(⬅️, ➡️) * 8
  change_y = btnp_axis(⬆️, ⬇️) * 8
  if get_tile(char_x + change_x, char_y + change_y) == 6 then
   temp_visuals = { change_x \ 4, change_y \ 4 }
   sfx(0)
   return
  end
  if change_x ~= 0 or change_y ~= 0 then
   sfx(31)
  end

  char_x += change_x
  char_y += change_y

  if (char_x + char_y >= 210) then
   local elapsed = time() - start_time
   results = {
    score = elapsed,
    happiness = 20 - elapsed \ 4,
    tickets = 3 - elapsed \ 20
   }

   start_time = time()
  end
 end
end

function _draw()
 cls()

 if results then
  print_centered("time: " .. pad(results.score, 3), 63, 60, 7)
  print_centered("+" .. min(15, results.happiness) .. " happiness", 63, 68, 10)
  print_centered("+" .. results.tickets .. " ticket" .. (results.tickets ~= 1 and "s" or ""), 63, 76, 9)
  return
 end

 map(map_x, map_y)
 map(0)
 if temp_visuals then
  pets[current_pet]:spr_scaled("thumbnail", char_x + temp_visuals[1], char_y + temp_visuals[2], 0.5)
  temp_visuals = nil
 else
  pets[current_pet]:spr_scaled("thumbnail", char_x, char_y, 0.5)
 end
end

function _end()
 pets[current_pet]:change_happiness(results.happiness)
 gacha_tickets = min(gacha_tickets + results.tickets, 0xff)
 flag_skip_title(true)
 save_data()
 extcmd("breadcrumb")
end

