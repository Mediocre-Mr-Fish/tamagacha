--//tab 2 maze
function maze_init()
 --max is 12,10
 map_x = flr(rnd(6))*2 + 15
 map_y = flr(rnd(5))*2 - 2
 char_x = 16
 char_y = 8
 tick⧗ = time()
 temp_visuals = nil
end

function maze_update()
 local change_x = char_x
 local change_y = char_y
 --moving
 if tick⧗ + 0.3 < time() then
	 if not (ordinal(⬅️,➡️) == 0 and ordinal(⬆️,⬇️) == 0) then
	  tick⧗ = time()
	 end
	 change_x = ordinal(⬅️,➡️) * 8
	 change_y = ordinal(⬆️,⬇️) * 8
		if get_tile(char_x + change_x, char_y + change_y) == 6 then
	  temp_visuals = {change_x\4, change_y\4}
	  --sfx() for bumping into wall
	  return
	 end
	 --sfx() for moving
	 char_x += change_x
	 char_y += change_y
		 
	 if (char_x + char_y >= 210) then
	  --game end
	  assert(false)
	 end
	end
end

function maze_draw()
 map(map_x, map_y)
 map(0)
 if temp_visuals then
  spr(22,char_x + temp_visuals[1], char_y + temp_visuals[2])
  temp_visuals = nil
 else
  spr(22,char_x, char_y)
 end
end


--maze helper funcs

function ordinal(in1, in2)
 if (btn(in1)) return -1
 if (btn(in2)) return 1
 return 0
end

function get_tile(x,y)
 local overlay_tile = mget(x\8, y\8)
 if overlay_tile ~= 0 then
  return overlay_tile
 end
 return mget(x\8 + map_x, y\8 + map_y)
end
