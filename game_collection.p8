pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
function _init()
 --[[
 0: math
 1: maze
 2: fishing
 3: secret
 --]]
 game = 2
 --load game from savedata
 if game == 0 then
  math_init()
 elseif game == 1 then
  maze_init()
 elseif game == 2 then
  fishing_init()
 elseif game == 3 then
  secret_init()
 end
 
 reward = {
  gacha_tickets = 2,
  food = 0,
  happiness = 15
 }
end

function _update()
 if game == 0 then
  math_update()
 elseif game == 1 then
  maze_update()
 elseif game == 2 then
  fishing_update()
 elseif game == 3 then
  secret_update()
 end
end



function _draw()
 cls()
 if game == 0 then
  math_draw()
 elseif game == 1 then
  maze_draw()
 elseif game == 2 then
  fishing_draw()
 elseif game == 3 then
  secret_draw()
 end
end
