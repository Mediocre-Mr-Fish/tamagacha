pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
#include pet.p8.lua

local mane = 1
local coat = 4
local spots = 15
local hooves = 5
local blush = 14
local ankles = 12
local ankles_shade = 13
local mouth = 2
local nose = 9
local highlight = 10

function variant(override)
 local var = {
  name = "horse", [mane] = navy, [coat] = brown, [spots] = brown,
  [hooves] = gray, [blush] = pink, [ankles] = white, [ankles_shade] = light_gray,
  [mouth] = gray, [nose] = white, [highlight] = light_gray
 }
 for k, v in pairs(override) do
  var[k] = v
 end
 return var
end

pet = {
 spr_maps = {
  { x = 0, y = 0, w = 2, h = 2, key = "thumbnail" },
  { x = 0, y = 2, w = 4, h = 4, key = "hd" },
  { x = 4, y = 2, w = 4, h = 4, key = "body" },
  { x = 8, y = 2, w = 4, h = 4, key = "head" },
  { x = 12, y = 2, w = 4, h = 4, key = "eye" }
 },
 transparent = 11, immortal = 0, rarity = 4,
 meat = 3, bone = 4,
 variants = {
  -- variant({ [spots] = beige }),
  -- variant({ [coat] = gray, [spots] = gray, [hooves] = brown }),
  -- variant({ [coat] = gray, [spots] = light_gray, [hooves] = brown, [mane] = black }),
  -- variant({ [coat] = gray, [spots] = light_gray, [hooves] = brown }),
  -- { name = "horse", [15] = 5, [4] = 6, [6] = 7, [1] = 5 }
 }
}

function table_search(tbl, val)
 for k, v in pairs(tbl) do
  if v == val then return k end
 end
end

local fur_colors = { black, brown, gray, light_gray, white, beige }

local light_colors = { light_gray, white, beige }
local dark_colors = { black, brown, gray }

function add_var(coat_color, spots_color, mane_color)
 local is_light_coat = table_search(light_colors, coat_color)

 if mane_color == navy and is_light_coat then
  mane_color = black
 end
 if spots_color == black and is_light_coat then
  spots_color = navy
 end

 if mane_color == beige and is_light_coat then
  return
 end

 if mane_color == coat_color then return end

 local var = {
  [coat] = coat_color,
  [spots] = spots_color,
  [mane] = mane_color
 }

 if spots_color ~= coat_color then
  var[highlight] = spots_color
  -- var[nose] = spots_color
 end

 add(pet.variants, variant(var))
end

for coat_color in all(fur_colors) do
 for spots_color in all({ black, brown, gray, light_gray, white, beige }) do
  for mane_color in all({ navy, brown, gray, beige }) do
   add_var(coat_color, spots_color, mane_color)
  end
 end
end

add(
 pet.variants, variant({
  name = "gunrock", weight = (#pet.variants + 1) \ 4,
  [coat] = navy, [spots] = navy, [mane] = gray,
  [mouth] = white, [nose] = navy, [highlight] = orange,
  [blush] = navy,
  [hooves] = orange
 })
)

