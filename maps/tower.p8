pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
source_list = {
    tower_segment = { x = 0, y = 0, w = 9, h = 5 },
    tower_ground = { x = 2, y = 5, w = 16, h = 10 }
}
function draw_map(key, x, y)
    local info = source_list[key]
    map(info.x, info.y, x, y, info.w, info.h)
end

function _init()
    t = time()
    state = 1
end
function _update()
    dt = time() - t
    t = time()

    if btnp(1) then
        state = state % 3 + 1
    end
    if btnp(0) then
        state = (state - 2) % 3 + 1
    end
end
function _draw()
    cls(12)
    palt(0, false)
    palt(11, true)
    if state == 1 then
        draw_map("tower_segment", 0, 64)
        draw_map("tower_segment", 0, 104)
    elseif state == 2 then
        for i = 0, 5 do
            draw_map("tower_segment", 0, i * 40 - (t * 240) % 40)
        end
    elseif state == 3 then
        draw_map("tower_segment", -16, -24)
        draw_map("tower_segment", -16, 16)
        draw_map("tower_ground", 0, 56)
    end
end

