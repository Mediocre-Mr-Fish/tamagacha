pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
function _init()
 init_cloud()
end

function init_cloud()
 cloud_x = 0
 cloud_y = flr(rnd(25)+15)
end

function _draw()
 cls()
 cloud_x += 0.1
 --house
 fillp(█)
 rectfill(0,0,128,70,15)
 
 --window
 rectfill(20,15,56,50,12)
 rect(20,15,56,50,7)
 rect(19,14,57,51,7)
 --add clouds here
 clip(21,15,35,35)
 if cloud_x > 53 then
  init_cloud()
 end
 sspr(112,16,16,16,cloud_x,cloud_y,16,16)
 clip()
 --middle
 line(38,15,38,50,7)
 line(37,15,37,50,7)
 
 --floor
 rectfill(0,70,128,128,4)
 rectfill(0,70,128,65,7)
 for i=0,40 do
  line(i*10, 71, i*10-20, 127, 9)
 end
 
end
__gfx__
