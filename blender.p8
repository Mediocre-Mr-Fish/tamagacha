pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
function _init()
 grim = true
 initial = 100
 button = 24
 flip_blade = false
 sfx0 = false
 ⧗ = time()
end

function under(length)
 return time() - ⧗ <= length
end

function slide(var, dest, timer, speed)
 speed = speed or 0.1
 if (time() - timer > 0.01) then
  return var + (dest - var) * speed
 end
end

function _update()
 if not grim then
  if under(4) then
   --repurposed button for pet sprite leaving
   button = slide(button, 128, ⧗, 0.025)
  else
   --return to home screen
   --delete pet from petlist
  end
  return
 end
 
 --if grim then
 if under(2) then
  initial = slide(initial,37,⧗)
 elseif under(3.7) then
  --blender button
  button = slide(button, 33, ⧗)
  --blender blade
  flip_blade = not flip_blade
 elseif under(6) then
  button = slide(button, 24, ⧗)
  initial = slide(initial,80,⧗)
 else
  --return to home screen
  --delete pet from petlist
 end
end

function _draw()
 cls()
 fillp(█)
 if not grim then
  if under(4) then
   local petname = "arb duck"
   print(petname.." is leaving", 30, 60, 6)
   rectfill(button + 16, 60, 128, 64, 0)
   sspr(24, 0, 16, 16, button, 48, 32, 32, true)
  end
  return
 end
 
 --if grim then
 pal()
 sspr(13,1,3,1,56,initial+40,12,4,flip_blade)
 if under(2.2) then
  sspr(24, 0, 16, 16, 45, 48, 32, 32)
 elseif under(3.7) then
  if not sfx0 then
   sfx0 = true
   sfx(0)
  end
  fillp(█)
	 rectfill(48,59,75,81, 8)
	 fillp(★)
	 rectfill(48,59,75,81, 14)
	 fillp(░)
	 rectfill(48,58,75,81, 7)
	 fillp(∧)
	 rectfill(48,58,75,81, 14)
	 pal(8,11)
	elseif under(6) then
	 print("+10 food", 63, 60, 4)
	 print("+10", 63, 66, 14)
	 spr(34, 77, 65)
 end
 sspr(8, 0, 16, 16, 28, initial, 64, 64)
 fillp(█)
 rectfill(28 + button,initial + 48, 28 + 3 + button, initial + 51, 6)
end
